<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Barangay System</title>
 
    <!-- Icons for menu and dashboard symbols -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
 
    <!-- Your own CSS file (optional custom styles) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
 
    <!-- ═══ NAVBAR ═══ -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Barangay Document Request System</a>
 
            <!-- Hamburger button for mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
 
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
 
                    @* Show these links only if logged in as Resident *@
                    @if (User.IsInRole("Resident"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="DocumentRequest" asp-action="Submit">
                                New Request
                            </a>
                        </li>
                        <li class="nav-item has-notification">
                            <a class="nav-link" asp-controller="DocumentRequest" asp-action="MyRequests">
                                My Requests
                                @await Component.InvokeAsync("ReadyRequestsBadge")
                            </a>
                        </li>
                    }
 
                    @* Show these links only if logged in as Admin *@
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="AllRequests">
                                All Requests
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Reports">
                                Reports
                            </a>
                        </li>
                    }
 
                    @* Show Login/Register if NOT logged in *@
                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
 
                    @* Show Logout if logged in *@
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-warning">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-light ms-2">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
 
    <!-- ═══ ALERTS (TempData messages) ═══ -->
    <div class="container mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>
 
    <!-- ═══ PAGE CONTENT ═══ -->
    <!-- Page content is rendered below -->
    <main class="container my-4">
        @RenderBody()
    </main>
 
    <!-- ═══ FOOTER ═══ -->
    <footer class="bg-light text-center py-3 mt-5 border-top">
        <small class="text-muted">Barangay Document Request System &copy; @DateTime.Now.Year</small>
    </footer>
 
    <!-- Bootstrap 5 JS (needed for dropdowns, collapse, alerts) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
