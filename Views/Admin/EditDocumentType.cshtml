@model BarangaySystem.Models.DocumentType
@{ ViewData["Title"] = "Edit Document Type"; }

<div class="row mb-4">
    <div class="col-md-8">
        <h2><i class="bi bi-pencil-square"></i> Edit Document Type</h2>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="DocumentTypes" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="UpdateDocumentType" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Fee" class="form-label">Fee</label>
                <input asp-for="Fee" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Fee" class="text-danger small"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="DocumentTypes" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
