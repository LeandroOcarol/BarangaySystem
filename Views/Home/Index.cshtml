@{
    ViewData["Title"] = "Barangay Document Request System";
}

<div class="container mt-5">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="text-center">
            <h1 class="display-4">Welcome @User.Identity.Name</h1>
        </div>
    }
    else
    {
        <div class="text-center">
            <h1 class="display-4">Welcome to Barangay Document Request System</h1>
            <p class="lead text-muted">A simple and secure portal for submitting and tracking barangay document requests.</p>
        </div>
    }
</div>
